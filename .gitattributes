# Force LF for shell scripts, source, and docs — these are interpreted on
# every platform and CRLF would break the shebang line on Unix / confuse the
# TypeScript/Node test runner.
*.sh        text eol=lf
*.ts        text eol=lf
*.md        text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Force CRLF for Windows-only scripts so `cmd.exe` doesn't choke on bare LF.
*.cmd       text eol=crlf
*.bat       text eol=crlf
*.ps1       text eol=crlf

# The bash shims (no extension) are executed by a POSIX shell — keep LF so the
# shebang line works. bin/tpmgr is the Windows-Git-Bash twin of bin/tpm.
bin/tpm     text eol=lf
bin/tpmgr   text eol=lf
